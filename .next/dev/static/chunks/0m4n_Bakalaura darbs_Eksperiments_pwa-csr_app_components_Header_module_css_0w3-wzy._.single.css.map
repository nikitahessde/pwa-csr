.header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(245,242,237,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.inner {
  max-width: 1200px; margin: 0 auto; padding: 0 24px;
  height: 60px; display: flex; align-items: center;
  justify-content: space-between; gap: 24px;
}
.brand { display: flex; align-items: center; gap: 10px; }
.logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.25rem; color: var(--text-primary); letter-spacing: -0.01em;
}
.badge {
  font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 2px 8px; border-radius: 100px;
  background: #1A1814; color: #F5F2ED;
}
.badgeCSR { background: var(--accent); color: #FFFFFF; }
.nav { display: flex; align-items: center; }
.countLinks {
  display: flex; align-items: center; gap: 2px;
  background: var(--border); border-radius: 100px; padding: 3px;
}
.countLink {
  font-size: 0.8rem; font-weight: 500; color: var(--text-secondary);
  padding: 4px 14px; border-radius: 100px; transition: all 0.15s ease;
}
.countLink:hover { color: var(--text-primary); }
.countLink.active {
  background: var(--bg-card); color: var(--text-primary);
  box-shadow: var(--shadow-sm);
}
@media (max-width: 480px) { .inner { padding: 0 16px; } }
